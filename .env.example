# Required — paste these two when deploying. Everything else is auto-detected.
DISCORD_BOT_TOKEN=replace-me
PATREON_CREATOR_TOKEN=replace-me

# Optional overrides
FOREMAN_TIER_NAME=Foreman
LOYAL_FOREMAN_ROLE_NAME=Loyal Foreman
TENURE_DAYS=90
LAPSE_GRACE_DAYS=7
CHECK_INTERVAL_MINUTES=60

# Persistent DB path. On Railway with a volume mounted at /data, leave this.
DB_PATH=/data/tenure.db
